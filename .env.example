# ═══════════════════════════════════════════════════════════
# VARIÁVEIS DE AMBIENTE - Painel de KPI (Cuide.me)
# ═══════════════════════════════════════════════════════════
# 
# ⚠️ ATENÇÃO: Este arquivo é apenas um TEMPLATE
# 
# Para usar:
# 1. Copie este arquivo: cp .env.example .env.local
# 2. Preencha os valores reais das variáveis
# 3. NUNCA commite .env.local no git (já está no .gitignore)
#
# Documentação completa: README.md e DEPLOYMENT.md
#
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────
# � ADMIN AUTH (OBRIGATÓRIO)
# ─────────────────────────────────────────────────────────
# Senha para acesso ao painel administrativo
# ⚠️ IMPORTANTE: Defina uma senha forte e única!
# Mínimo: 12 caracteres, letras, números e símbolos

ADMIN_PASSWORD=sua_senha_forte_aqui_minimo_12_caracteres

# ─────────────────────────────────────────────────────────
# �🔥 FIREBASE ADMIN SDK (BACKEND)
# ─────────────────────────────────────────────────────────
# Obtenha em: https://console.firebase.google.com/
# Project Settings > Service Accounts > Generate New Private Key
#
# Download o JSON e extraia os valores abaixo:

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIB...\n-----END PRIVATE KEY-----\n"

# Alias historicos ainda encontrados em documentacao antiga:
# FIREBASE_ADMIN_PROJECT_ID / FIREBASE_ADMIN_CLIENT_EMAIL / FIREBASE_ADMIN_PRIVATE_KEY
# O runtime atual nao le esses nomes diretamente.

# Opcao alternativa: Base64 do JSON completo
# FIREBASE_ADMIN_SERVICE_ACCOUNT=eyJ0eXBlIjoic2Vydmlj...

# ─────────────────────────────────────────────────────────
# 🔥 FIREBASE CLIENT (FRONTEND) - Opcional
# ─────────────────────────────────────────────────────────
# Configurações públicas do Firebase (se usar autenticação frontend)

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:xxxxxxxxxxxx

# ─────────────────────────────────────────────────────────
# 💳 STRIPE
# ─────────────────────────────────────────────────────────
# Obtenha em: https://dashboard.stripe.com/apikeys
# 
# Para Desenvolvimento: use sk_test_xxxxx
# Para Produção: use sk_live_xxxxx
# ⚠️ NUNCA exponha a SECRET KEY no frontend!

STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────
# 📊 GOOGLE ANALYTICS 4 - Opcional
# ─────────────────────────────────────────────────────────
# Property ID usado pelo painel server-side.
# Pode ser informado como `123456789` ou `properties/123456789`.

GA4_PROPERTY_ID=123456789

# ─────────────────────────────────────────────────────────
# 🔐 AUTENTICACAO ADMIN
# ─────────────────────────────────────────────────────────
# O runtime atual de login usa somente ADMIN_PASSWORD.
# ADMIN_EMAIL e ADMIN_PASSWORD_HASH nao sao consumidos pela rota ativa.

# ─────────────────────────────────────────────────────────
# 🔔 WEBHOOKS - Opcional
# ─────────────────────────────────────────────────────────
# Token secreto para autenticar webhooks externos
# Gere com: openssl rand -hex 32

WEBHOOK_SECRET_TOKEN=seu-token-secreto-de-64-caracteres-aqui

# ─────────────────────────────────────────────────────────
# ⚙️ NEXT.JS
# ─────────────────────────────────────────────────────────

# URL base da aplicação
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ambiente (development, production, test)
NODE_ENV=development

# ─────────────────────────────────────────────────────────
# 📊 GOOGLE ANALYTICS 4 (GA4)
# ─────────────────────────────────────────────────────────
# 
# Credenciais da service account do Google Analytics Data API.
# Aceita JSON direto ou base64 do JSON completo.
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Measurement ID publico nao e exigido pelo painel atual.
# Se algum cliente futuro consumir analytics no browser, documentar o nome efetivo usado antes de adicionar aqui.

# ─────────────────────────────────────────────────────────
# 🌐 URLS
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────
# 🔐 ADMIN (Opcional)
# ─────────────────────────────────────────────────────────
# ADMIN_PASSWORD=sua_senha_segura_aqui

# ═══════════════════════════════════════════════════════
# 📝 Documentação completa: ver INTEGRATIONS_SETUP.md
# ═══════════════════════════════════════════════════════
